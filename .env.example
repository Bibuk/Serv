# Database
DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME_POSTGRES@postgres:5432/twoltp
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES
POSTGRES_DB=twoltp

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# JWT — must be ≥32 random characters, generated e.g. with: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_MIN_32_CHARS_RANDOM_SECRET
JWT_ALGORITHM=HS256
# Long-lived tokens by design: the session must never be dropped by token
# expiry (e.g. during a live demo). Access ≈ 1 year, refresh ≈ 10 years.
# Lower these (e.g. 15 / 7) if you need stricter expiry-driven logouts.
ACCESS_TOKEN_EXPIRE_MINUTES=525600
REFRESH_TOKEN_EXPIRE_DAYS=3650

# CORS — comma-separated list of allowed frontend origins
# Include your actual server IP/domain when deploying
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Email
MAIL_USERNAME=noreply@example.com
MAIL_PASSWORD=CHANGE_ME_MAIL_PASSWORD
MAIL_FROM=noreply@example.com
MAIL_PORT=587
MAIL_SERVER=smtp.example.com
MAIL_STARTTLS=true
MAIL_SSL_TLS=false

# File uploads
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=50

# App
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
# Set SECURE_COOKIES=true ONLY when the site is served over HTTPS.
# With HTTP (e.g. IP-only demo server) leave it false — otherwise the
# browser won't send cookies back and users will be logged out on refresh.
SECURE_COOKIES=false
