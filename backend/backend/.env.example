# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/2ltp

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-in-production-use-256-bit-random-key
JWT_ALGORITHM=HS256
# Long-lived tokens by design — session is never dropped by token expiry.
# Access ≈ 1 year, refresh ≈ 10 years. Lower these for stricter logouts.
ACCESS_TOKEN_EXPIRE_MINUTES=525600
REFRESH_TOKEN_EXPIRE_DAYS=3650

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Email (SMTP)
MAIL_USERNAME=no-reply@example.com
MAIL_PASSWORD=smtp-password
MAIL_FROM=no-reply@example.com
MAIL_PORT=587
MAIL_SERVER=smtp.example.com
MAIL_STARTTLS=True
MAIL_SSL_TLS=False

# File storage
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=50

# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
